# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── LDAP / Active Directory ──────────────────────────────────────────────────
# Use ldap:// (port 389, plain) or ldaps:// (port 636, TLS) depending on your AD
LDAP_URL=ldap://10.0.0.1:389

# Base Distinguished Name — root of your domain
LDAP_BASE_DN=DC=yourdomain,DC=local

# Primary UPN suffix (user@LDAP_DEFAULT_UPN is tried first)
LDAP_DEFAULT_UPN=yourdomain.com

# Alternate UPN suffix (user@LDAP_ALT_UPN is tried if primary fails)
LDAP_ALT_UPN=yourdomain.local

# NetBIOS / short domain name (used for DOMAIN\username bind format)
LDAP_NETBIOS=YOURDOMAIN

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_min_64_chars

# Token lifetime — 8h matches a standard government work shift
JWT_EXPIRES_IN=8h
