# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5050
CLIENT_URL=http://localhost:3030

# ─── LDAP / Active Directory ──────────────────────────────────────────────────
LDAP_URL=ldap://10.27.16.5
LDAP_BASE_DN=DC=swd,DC=local
LDAP_DEFAULT_UPN=swd.bh
LDAP_ALT_UPN=swd.local
LDAP_NETBIOS=SWD

# Service account for browsing the directory (used by the Users page to list all AD users).
# Use a read-only account — no special permissions needed beyond Read on the user objects.
# Format can be UPN (user@swd.bh) or distinguished name (CN=svc,OU=...,DC=...).
# Leave blank to disable the AD user browser (local users table still works).
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=8h

# ─── Super Admin Override ──────────────────────────────────────────────────
# Comma-separated usernames or emails that always get SUPER_ADMIN
# regardless of their AD group memberships.
SUPER_ADMIN_USERS=a.alkubaesy

# ─── SMTP ───────────────────────────────────────────────────────────────────
SMTP_HOST=10.27.16.4
SMTP_PORT=25
SMTP_FROM_DEFAULT="Doc Tracking <doctracking@swd.bh>"
APP_URL=http://localhost:3030
