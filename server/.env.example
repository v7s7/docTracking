# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5050
CLIENT_URL=http://localhost:3030

# ─── LDAP / Active Directory ──────────────────────────────────────────────────
LDAP_URL=ldap://10.0.0.1:389
LDAP_BASE_DN=DC=yourdomain,DC=local
LDAP_DEFAULT_UPN=yourdomain.com
LDAP_ALT_UPN=yourdomain.local
LDAP_NETBIOS=YOURDOMAIN

# Service account for browsing the directory (used by the Users page to list all AD users).
# Use a read-only account — no special permissions needed beyond Read on the user objects.
# Format can be UPN (svc@yourdomain.com) or distinguished name (CN=svc,OU=...,DC=...).
LDAP_BIND_DN=svc_doctrack@yourdomain.com
LDAP_BIND_PASSWORD=ServiceAccountPassword

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=8h

# ─── Super Admin Override ──────────────────────────────────────────────────
# Comma-separated usernames or emails that always get SUPER_ADMIN
# regardless of their AD group memberships.
SUPER_ADMIN_USERS=a.alkubaesy

# ─── SMTP ───────────────────────────────────────────────────────────────────
SMTP_HOST=10.0.0.2
SMTP_PORT=25
SMTP_FROM_DEFAULT="Doc Tracking <doctracking@yourdomain.com>"
APP_URL=http://localhost:3030
